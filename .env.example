# Root orchestration currently has no required runtime secrets.
#
# Keep real values in .env.local or your shell environment.

# Backend Mapbox API calls and docker-compose frontend map rendering.
MAPBOX_API_BASE_URL=https://api.mapbox.com
MAPBOX_ACCESS_TOKEN=

# compose passes MAPBOX_ACCESS_TOKEN to Vite as VITE_MAPBOX_ACCESS_TOKEN.

