# Copy this file to .env at the repository root for Docker Compose.
# Do not commit .env. Share real team values through the team's secret channel.

# Application
SPRING_PROFILES_ACTIVE=local
SERVER_PORT=8080
FRONTEND_PORT=5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# For external access with dynamic preview/public hosts, prefer exact origins when possible.
# Example: CORS_ALLOWED_ORIGIN_PATTERNS=https://*.example.com,https://*.ngrok-free.app
CORS_ALLOWED_ORIGIN_PATTERNS=
VITE_API_BASE_URL=/api/v1

# PostgreSQL container and backend datasource
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soomgil
DB_USERNAME=soomgil
DB_PASSWORD=change-me

# Redis container and backend client
REDIS_HOST=localhost
REDIS_PORT=6379

# Mailpit
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_WEB_PORT=8025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_VERIFICATION_BASE_URL=http://localhost:5173/auth/verify-email
MAIL_RESET_BASE_URL=http://localhost:5173/auth/reset-password
MAIL_FROM=noreply@soomgil.com

# JWT. Replace in shared/dev environments with a generated Base64 secret.
JWT_SECRET=Y2hhbmdlLW1lLWxvY2FsLWRldi1zZWNyZXQtZm9yLWp3dC1oczI1Ni1vbmx5
JWT_ISSUER=soomgil
JWT_ACCESS_TOKEN_TTL_SECONDS=900

# OAuth
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:5173/auth/oauth/kakao/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/oauth/google/callback

# Gemini / Spring AI
AI_CHAT_MODEL=google-genai
GMS_API_KEY=
GMS_GEMINI_ENABLED=true
GMS_GEMINI_BASE_URL=https://gms.ssafy.io/gmsapi/generativelanguage.googleapis.com
GMS_GEMINI_API_VERSION=v1beta
GMS_CHAT_MODEL=gpt-5.5
GEMINI_CHAT_MODEL=gemini-2.5-flash-lite

# Korea Tourism Organization
KTO_API_BASE_URL=https://apis.data.go.kr/B551011/KorService2
KTO_API_KEY=

# Mapbox. Compose also passes this to Vite as VITE_MAPBOX_ACCESS_TOKEN.
MAPBOX_API_BASE_URL=https://api.mapbox.com
MAPBOX_ACCESS_TOKEN=

# MinIO / S3-compatible local storage
MINIO_ROOT_USER=soomgil
MINIO_ROOT_PASSWORD=change-me-change-me
S3_ENDPOINT=http://minio:9000
S3_REGION=ap-northeast-2
S3_BUCKET=soomgil-local
S3_PUBLIC_BASE_URL=http://localhost:9000/soomgil-local
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ACCESS_KEY=soomgil
S3_SECRET_KEY=change-me-change-me

