Table record.trip_record_entries {
  id uuid [pk, not null]
  trip_id uuid [not null]
  itinerary_day_id uuid
  itinerary_item_id uuid
  uploaded_by_user_id uuid [not null]
  title varchar(160)
  caption text
  location_name varchar(240)
  lat numeric(10,7)
  lng numeric(10,7)
  taken_at timestamptz
  visibility varchar(30) [not null, default: `'TRIP_MEMBERS'::character varying`]
  status varchar(30) [not null, default: `'ACTIVE'::character varying`]
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz

  Indexes {
    created_at [name: 'trip_record_entries_created_at_idx']
    itinerary_day_id [name: 'trip_record_entries_itinerary_day_id_idx']
    itinerary_item_id [name: 'trip_record_entries_itinerary_item_id_idx']
    status [name: 'trip_record_entries_status_idx']
    taken_at [name: 'trip_record_entries_taken_at_idx']
    trip_id [name: 'trip_record_entries_trip_id_idx']
    uploaded_by_user_id [name: 'trip_record_entries_uploaded_by_user_id_idx']
  }
}

Table record.trip_record_media {
  record_entry_id uuid [not null]
  media_file_id uuid [not null]
  sort_order int [not null, default: `0`]
  caption text
  created_at timestamptz [not null]

  Indexes {
    (record_entry_id, media_file_id) [pk, name: 'trip_record_media_pkey']
    media_file_id [name: 'trip_record_media_media_file_id_idx']
    (record_entry_id, sort_order) [name: 'trip_record_media_record_sort_order_idx']
  }
}

Table social.user_follows {
  follower_user_id uuid [not null]
  following_user_id uuid [not null]
  status varchar(20) [not null, default: `'ACTIVE'::character varying`]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    (follower_user_id, following_user_id) [pk, name: 'user_follows_pkey']
    (following_user_id, status) [name: 'idx_social_user_follows_following_status']
    following_user_id [name: 'idx_social_user_follows_following_user_id']
    status [name: 'idx_social_user_follows_status']
  }
}

Table tourism_source.attraction_images {
  id uuid [pk, not null]
  attraction_no int [not null]
  source_provider varchar(80) [not null, default: `'KTO'::character varying`]
  source_type varchar(40) [not null]
  original_url text
  storage_provider varchar(40)
  bucket varchar(120)
  object_key text
  public_url text [not null]
  display_order int [not null, default: `999`]
  width int
  height int
  checksum_sha256 varchar(128)
  is_active bool [not null, default: `true`]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (attraction_no, is_active, display_order, created_at) [name: 'idx_attraction_images_display']
  }
}

Table tourism_source.attractions {
  no int [pk, not null, increment]
  content_id int [not null, unique]
  title varchar(500) [not null]
  content_type_id int
  area_code int
  si_gun_gu_code int
  first_image1 text
  first_image2 text
  map_level int
  latitude double
  longitude double
  tel varchar(80)
  addr1 varchar(300)
  addr2 varchar(300)
  homepage text
  overview text
  source_hash varchar(128)
  source_modified_at timestamptz
  imported_at timestamptz [not null, default: `now()`]

  Indexes {
    content_type_id [name: 'idx_attractions_content_type']
    (longitude, latitude) [name: 'idx_attractions_location']
    (area_code, si_gun_gu_code) [name: 'idx_attractions_region']
    title [name: 'idx_attractions_title']
  }
}

Table tourism_source.contenttypes {
  content_type_id int [pk, not null]
  content_type_name varchar(100) [not null]
}

Table tourism_source.contest_award_photo_matches {
  id uuid [pk, not null]
  photo_id uuid [not null]
  attraction_no int
  sido_code int
  gugun_code int
  match_scope varchar(30) [not null]
  match_status varchar(30) [not null]
  match_method varchar(40) [not null]
  confidence numeric(5,4)
  is_selected bool [not null, default: `false`]
  rationale text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (attraction_no, match_scope, match_status, is_selected) [name: 'idx_contest_award_photo_matches_attraction']
    (sido_code, gugun_code, match_scope, match_status, is_selected) [name: 'idx_contest_award_photo_matches_region']
  }
}

Table tourism_source.contest_award_photos {
  id uuid [pk, not null]
  contest_id uuid
  award_year int [not null]
  award_name varchar(160)
  award_rank int [not null, default: `999`]
  title varchar(240)
  photographer_name varchar(120)
  original_file_name varchar(500) [not null]
  extracted_region_text varchar(240)
  storage_provider varchar(40) [not null, default: `'S3'::character varying`]
  bucket varchar(120)
  object_key text [not null]
  public_url text
  mime_type varchar(120)
  byte_size bigint
  width int
  height int
  checksum_sha256 varchar(128)
  upload_status varchar(30) [not null, default: `'DOWNLOADED'::character varying`]
  rights_status varchar(30) [not null, default: `'PENDING_REVIEW'::character varying`]
  license_note text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    contest_id [name: 'idx_contest_award_photos_contest']
    (upload_status, rights_status, award_year, award_rank) [name: 'idx_contest_award_photos_public_status']
  }
}

Table tourism_source.guguns {
  sido_code int [not null]
  gugun_code int [not null]
  gugun_name varchar(120) [not null]

  Indexes {
    (sido_code, gugun_code) [pk, name: 'guguns_pkey']
    sido_code [name: 'idx_guguns_sido']
  }
}

Table tourism_source.photo_contests {
  id uuid [pk, not null]
  provider varchar(80) [not null, default: `'KTO_CONTENTS_LAB'::character varying`]
  contest_name varchar(200) [not null]
  award_year int [not null]
  contest_round varchar(80)
  source_url text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    award_year [name: 'idx_photo_contests_award_year']
  }
}

Table tourism_source.region_aliases {
  id uuid [pk, not null]
  alias varchar(120) [not null]
  normalized_alias varchar(120) [not null]
  sido_code int
  gugun_code int
  alias_type varchar(40) [not null]
  is_active bool [not null, default: `true`]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    is_active [name: 'idx_region_aliases_active']
    normalized_alias [name: 'idx_region_aliases_normalized_alias']
    (sido_code, gugun_code) [name: 'idx_region_aliases_region']
  }
}

Table tourism_source.sidos {
  sido_code int [pk, not null]
  sido_name varchar(120) [not null]
}

Table trip.trip_invites {
  id uuid [pk, not null]
  trip_id uuid [not null]
  created_by_user_id uuid [not null]
  invitee_user_id uuid
  invite_code varchar(32) [not null]
  invite_token_hash text [not null, unique]
  status varchar(30) [not null, default: `'PENDING'::character varying`]
  expires_at timestamptz
  accepted_by_user_id uuid
  accepted_at timestamptz
  revoked_at timestamptz
  created_at timestamptz [not null]

  Indexes {
    invite_code [name: 'trip_invites_invite_code_idx']
    invitee_user_id [name: 'trip_invites_invitee_user_id_idx']
    status [name: 'trip_invites_status_idx']
    trip_id [name: 'trip_invites_trip_id_idx']
  }
}

Table trip.trip_members {
  id uuid [pk, not null]
  trip_id uuid [not null]
  user_id uuid [not null]
  role varchar(20) [not null, default: `'MEMBER'::character varying`]
  status varchar(30) [not null, default: `'ACTIVE'::character varying`]
  joined_at timestamptz [not null]
  left_at timestamptz
  removed_by_user_id uuid

  Indexes {
    (trip_id, user_id) [unique, name: 'trip_members_trip_user_unique']
    status [name: 'trip_members_status_idx']
    (trip_id, role) [name: 'trip_members_trip_id_role_idx']
    user_id [name: 'trip_members_user_id_idx']
  }
}

Table trip.trip_regions {
  trip_id uuid [not null]
  legal_region_code varchar(10) [not null]
  sort_order int [not null, default: `0`]
  created_at timestamptz [not null]

  Indexes {
    (trip_id, legal_region_code) [pk, name: 'trip_regions_pkey']
    legal_region_code [name: 'trip_regions_legal_region_code_idx']
  }
}

Table trip.trips {
  id uuid [pk, not null]
  owner_user_id uuid [not null]
  title varchar(160) [not null]
  display_destination varchar(160)
  status varchar(30) [not null, default: `'ACTIVE'::character varying`]
  itinerary_version bigint [not null, default: `0`]
  retripped_from_post_id uuid
  retripped_from_snapshot_version int
  created_at timestamptz [not null]
  updated_at timestamptz [not null]
  deleted_at timestamptz

  Indexes {
    created_at [name: 'trip_trips_created_at_idx']
    owner_user_id [name: 'trip_trips_owner_user_id_idx']
    retripped_from_post_id [name: 'trip_trips_retripped_from_post_id_idx']
    status [name: 'trip_trips_status_idx']
  }
}

