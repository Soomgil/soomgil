Project soomgil {
  database_type: 'PostgreSQL'
  Note: '''
  Soomgil production V1 data model.

  Source of truth:
  - .agent/contracts/backend_contract_decisions.md
  - .agent/docs/product-specs/service_requirements.md

  Conventions:
  - Public/product resource IDs use UUID.
  - Internal event/audit streams may use bigserial.
  - User-facing extensible concepts use tables or code-managed rows instead of PostgreSQL enums.
  - Tables are grouped by PostgreSQL schema-qualified names such as auth.users and trip.trips.
  - Production service schemas do not store external place master data; places are referenced by provider + external_place_id.
  - tourism_source.* is a separate enrichment/source namespace for tag extraction, source matching, and public tourism image candidates.
  - tourism_source may be deployed as a physically separate database; this DBML keeps it in one contract file for cross-domain visibility.
  - Routes are stored as itinerary item-to-item segments, not day-owned records.
  - Community post snapshots store immutable display data needed to render after source changes.
  '''
}

// ============================================================
// External Tourism Source Data for Tag Extraction
// ============================================================

Table tourism_source.sidos {
  no int [pk, increment, note: 'Source row id.']
  sido_code int [not null, unique, note: 'KTO/SSAFY sido code.']
  sido_name varchar(20)

  Indexes {
    sido_code [unique]
  }

  Note: 'Source-region table imported from KTO/SSAFY-style tourism data. Not a production service domain table.'
}

Table tourism_source.guguns {
  no int [pk, increment, note: 'Source row id.']
  sido_code int [not null]
  gugun_code int [not null]
  gugun_name varchar(20)

  Indexes {
    (sido_code, gugun_code) [unique]
    sido_code
    gugun_code
  }

  Note: 'Source subregion table. Composite sido_code + gugun_code identifies a region within the source dataset.'
}

Table tourism_source.contenttypes {
  content_type_id int [pk, note: 'KTO content type id.']
  content_type_name varchar(45)

  Note: 'Source content type dictionary used for attraction import and tag extraction hints.'
}

Table tourism_source.attractions {
  no int [pk, increment, note: 'Source attraction row id.']
  content_id int [note: 'KTO content id. Used as external_place_id when present.']
  title varchar(500)
  content_type_id int
  area_code int [note: 'Sido code.']
  si_gun_gu_code int [note: 'Gugun code within area_code.']
  first_image1 text
  first_image2 text
  map_level int
  latitude decimal(20,17)
  longitude decimal(20,17)
  tel varchar(40)
  addr1 varchar(200)
  addr2 varchar(200)
  homepage text
  overview text
  source_hash varchar(128)
  source_modified_at timestamptz
  imported_at timestamptz [not null, default: `now()`]

  Indexes {
    content_id
    title
    content_type_id
    area_code
    (area_code, si_gun_gu_code)
    (latitude, longitude)
  }

  Note: 'Attraction source data used for tag extraction and source matching. This is not the user-facing service place master.'
}

Table tourism_source.attraction_images {
  id uuid [pk, default: `gen_random_uuid()`]
  attraction_no int [not null]
  source_provider varchar(80) [not null, default: 'KTO']
  source_type varchar(40) [not null, note: 'FIRST_IMAGE1, FIRST_IMAGE2, DETAIL_IMAGE, MANUAL']
  original_url text
  storage_provider varchar(40) [note: 'EXTERNAL_URL, S3']
  bucket varchar(120)
  object_key text
  public_url text [not null]
  display_order int [not null, default: 999]
  width int
  height int
  checksum_sha256 varchar(128)
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    attraction_no
    source_provider
    source_type
    display_order
    is_active
  }

  Note: 'Normal tourism image candidates used before mixing in contest award photos. Enables the 4 normal + 1 award-photo display policy.'
}

Table tourism_source.region_aliases {
  id uuid [pk, default: `gen_random_uuid()`]
  alias varchar(120) [not null]
  normalized_alias varchar(120) [not null]
  sido_code int
  gugun_code int
  alias_type varchar(40) [not null, note: 'FILE_NAME_TOKEN, COMMON_NAME, ADMIN_NAME, MANUAL']
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    normalized_alias
    (sido_code, gugun_code)
    alias_type
    is_active
  }

  Note: 'Region alias dictionary for matching award photo file names to source regions.'
}

Table tourism_source.photo_contests {
  id uuid [pk, default: `gen_random_uuid()`]
  provider varchar(80) [not null, default: 'KTO_CONTENTS_LAB']
  contest_name varchar(200) [not null]
  award_year int [not null]
  contest_round varchar(80)
  source_url text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    provider
    award_year
    contest_name
  }

  Note: 'Korea Tourism Organization Contents Lab contest metadata for downloaded award photos.'
}

Table tourism_source.contest_award_photos {
  id uuid [pk, default: `gen_random_uuid()`]
  contest_id uuid
  award_year int [not null]
  award_name varchar(160)
  award_rank int [not null, default: 999, note: 'Lower rank sorts first within the same award year.']
  title varchar(240)
  photographer_name varchar(120)
  original_file_name varchar(500) [not null]
  extracted_region_text varchar(240)
  storage_provider varchar(40) [not null, default: 'S3']
  bucket varchar(120)
  object_key text [not null]
  public_url text
  mime_type varchar(120)
  byte_size bigint
  width int
  height int
  checksum_sha256 varchar(128)
  upload_status varchar(30) [not null, default: 'DOWNLOADED', note: 'DOWNLOADED, UPLOADED, FAILED']
  license_note text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    contest_id
    award_year
    award_rank
    original_file_name
    object_key
    upload_status
  }

  Note: 'Downloaded contest award photo metadata. Binary files live in S3-compatible storage, not in the database.'
}

Table tourism_source.contest_award_photo_matches {
  id uuid [pk, default: `gen_random_uuid()`]
  photo_id uuid [not null]
  attraction_no int
  sido_code int
  gugun_code int
  match_scope varchar(30) [not null, note: 'ATTRACTION, REGION, UNMATCHED']
  match_status varchar(30) [not null, note: 'CANDIDATE, SELECTED, REJECTED, AMBIGUOUS']
  match_method varchar(40) [not null, note: 'FILE_NAME_REGION, TITLE_TEXT, MANUAL, IMPORT_METADATA']
  confidence decimal(5,4)
  is_selected boolean [not null, default: false]
  rationale text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    photo_id
    attraction_no
    (sido_code, gugun_code)
    match_scope
    match_status
    match_method
    is_selected
  }

  Note: 'A contest photo may be matched to an exact attraction, region only, or remain unmatched for future use.'
}

// ============================================================
// Identity and Access
// ============================================================

Table auth.users {
  id uuid [pk, default: `gen_random_uuid()`]
  status varchar(30) [not null, default: 'ACTIVE', note: 'ACTIVE, SUSPENDED, PENDING_DELETION, DELETED']
  status_reason varchar(255)
  status_changed_at timestamptz [not null, default: `now()`]
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deletion_requested_at timestamptz
  deletion_scheduled_at timestamptz
  deleted_at timestamptz

  Indexes {
    status
    status_changed_at
    created_at
    deletion_scheduled_at
    deleted_at
  }

  Note: 'Account lifecycle anchor. Login identifiers, profile display fields, settings, and credentials are separated for privacy, uniqueness, and provider expansion.'
}

Table auth.user_email_addresses {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  email varchar(320) [not null]
  normalized_email varchar(320) [not null, note: 'Lowercase/canonical email used for login and uniqueness.']
  is_primary boolean [not null, default: false]
  verified_at timestamptz
  verification_last_sent_at timestamptz
  removed_at timestamptz
  removed_reason varchar(120)
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (normalized_email, `case when removed_at is null then normalized_email else id::text end`) [unique, name: 'uq_auth_user_email_addresses_active_normalized_email']
    (user_id, `case when is_primary and removed_at is null then user_id else id end`) [unique, name: 'uq_auth_user_email_addresses_one_active_primary']
    user_id
    normalized_email
    verified_at
    removed_at
  }

  Note: 'Stores login email history. Raw verification tokens are never stored; token tables keep hashes only.'
}

Table auth.user_profiles {
  user_id uuid [pk]
  display_name varchar(80) [not null]
  profile_image_url text
  profile_media_file_id uuid
  bio varchar(500)
  profile_visibility varchar(20) [not null, default: 'PUBLIC', note: 'PUBLIC or PRIVATE. PRIVATE profiles require approved follow for full profile visibility.']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    display_name
    profile_media_file_id
    profile_visibility
  }
}

Table auth.user_settings {
  user_id uuid [pk]
  display_language varchar(12) [not null, default: 'ko']
  timezone varchar(50) [not null, default: 'Asia/Seoul']
  marketing_email_opt_in boolean [not null, default: false]
  marketing_email_opted_in_at timestamptz
  marketing_email_opted_out_at timestamptz
  trip_invite_email_opt_in boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table auth.auth_providers {
  id smallserial [pk]
  code varchar(40) [not null, unique, note: 'LOCAL, KAKAO, GOOGLE. Add rows for NAVER, APPLE, etc.']
  display_name varchar(80) [not null]
  auth_type varchar(30) [not null, default: 'OAUTH2', note: 'LOCAL, OAUTH2, OIDC']
  issuer text
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table auth.user_password_credentials {
  user_id uuid [pk]
  password_hash varchar(255) [not null]
  password_algorithm varchar(40) [not null, default: 'bcrypt', note: 'bcrypt or argon2id; raw passwords are never stored.']
  password_hash_params jsonb
  password_changed_at timestamptz [not null, default: `now()`]
  failed_login_count int [not null, default: 0]
  locked_until timestamptz
  last_failed_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    locked_until
  }
}

Table auth.user_auth_identities {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  provider_id smallint [not null]
  provider_subject varchar(255) [not null]
  provider_email varchar(320)
  provider_email_verified boolean [not null, default: false]
  provider_display_name varchar(120)
  provider_profile jsonb
  linked_at timestamptz [not null, default: `now()`]
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (provider_id, provider_subject) [unique]
    user_id
    (provider_id, provider_email)
  }

  Note: 'External social login identity. OAuth access/refresh tokens are not stored here.'
}

Table auth.user_sessions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  refresh_token_hash varchar(255) [not null, unique]
  refresh_token_family_id uuid [not null, default: `gen_random_uuid()`]
  refresh_token_version int [not null, default: 1]
  device_name varchar(120)
  device_os varchar(120)
  ip_address_hash varchar(255)
  user_agent_hash varchar(255)
  last_used_at timestamptz
  last_refreshed_at timestamptz
  expires_at timestamptz [not null]
  revoked_at timestamptz
  revoked_by_user_id uuid
  revocation_reason varchar(120)
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
    refresh_token_hash [unique]
    refresh_token_family_id
    expires_at
    revoked_at
  }

  Note: 'Refresh/session token store for rotation and revocation. Store token hashes only.'
}

Table auth.user_email_verification_tokens {
  id uuid [pk, default: `gen_random_uuid()`]
  user_email_address_id uuid [not null]
  token_hash varchar(255) [not null, unique]
  requested_by_ip_hash varchar(255)
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_email_address_id
    token_hash [unique]
    expires_at
    used_at
  }
}

Table auth.user_password_reset_tokens {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  token_hash varchar(255) [not null, unique]
  requested_by_ip_hash varchar(255)
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
    token_hash [unique]
    expires_at
    used_at
  }
}

Table auth.policy_documents {
  id uuid [pk, default: `gen_random_uuid()`]
  policy_code varchar(80) [not null, note: 'TERMS_OF_SERVICE, PRIVACY_POLICY, MARKETING_CONSENT']
  version varchar(40) [not null]
  language_code varchar(12) [not null, default: 'ko']
  title varchar(160) [not null]
  content_url text
  content_hash varchar(128)
  is_required boolean [not null, default: true]
  published_at timestamptz [not null]
  retired_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (policy_code, version, language_code) [unique]
    policy_code
    published_at
    retired_at
  }
}

Table auth.user_policy_acceptances {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  policy_document_id uuid [not null]
  acceptance_method varchar(40) [not null, note: 'SIGNUP, SETTINGS, FORCED_UPDATE, ADMIN']
  accepted_at timestamptz [not null, default: `now()`]
  ip_address_hash varchar(255)
  user_agent_hash varchar(255)
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (user_id, policy_document_id) [unique]
    policy_document_id
    accepted_at
  }
}

Table auth.roles {
  id smallserial [pk]
  code varchar(40) [not null, unique, note: 'SUPER_ADMIN, ADMIN, MODERATOR']
  display_name varchar(80) [not null]
  description text
  is_system boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table auth.user_roles {
  user_id uuid [not null]
  role_id smallint [not null]
  granted_by_user_id uuid
  granted_at timestamptz [not null, default: `now()`]
  revoked_at timestamptz
  revoked_by_user_id uuid
  revocation_reason varchar(120)

  Indexes {
    (user_id, role_id) [pk]
    role_id
    granted_by_user_id
    revoked_by_user_id
    revoked_at
  }
}

Table auth.user_security_events {
  id bigserial [pk]
  user_id uuid
  actor_user_id uuid
  provider_id smallint
  normalized_identifier varchar(320)
  event_type varchar(80) [not null, note: 'LOGIN_SUCCESS, LOGIN_FAILURE, PASSWORD_RESET_REQUESTED, PASSWORD_CHANGED, SESSION_REVOKED']
  success boolean [not null, default: false]
  failure_reason varchar(120)
  ip_address_hash varchar(255)
  user_agent_hash varchar(255)
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
    actor_user_id
    provider_id
    normalized_identifier
    event_type
    (ip_address_hash, created_at)
    created_at
  }
}

// ============================================================
// Social Graph
// ============================================================

Table social.user_follows {
  follower_user_id uuid [not null]
  following_user_id uuid [not null]
  status varchar(20) [not null, default: 'ACTIVE', note: 'PENDING for private profile follow request, ACTIVE for approved follow, DELETED for unfollow/rejected request.']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    (follower_user_id, following_user_id) [pk]
    following_user_id
    (following_user_id, status)
    status
  }

  Note: 'Application prevents self-follow. Private profile follow starts as PENDING and becomes ACTIVE only after approval.'
}

// ============================================================
// Media
// ============================================================

Table media.media_files {
  id uuid [pk, default: `gen_random_uuid()`]
  owner_user_id uuid
  storage_provider varchar(40) [not null, default: 'S3_COMPATIBLE']
  bucket varchar(120) [not null]
  object_key text [not null]
  public_url text
  mime_type varchar(120)
  byte_size bigint
  width int
  height int
  linked_resource_type varchar(60)
  linked_resource_id uuid
  status varchar(30) [not null, default: 'ACTIVE', note: 'ACTIVE after upload metadata is verified, DELETED after soft delete, PURGED after object deletion.']
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz
  purge_after_at timestamptz
  purged_at timestamptz

  Indexes {
    owner_user_id
    (linked_resource_type, linked_resource_id)
    status
  }
}

// ============================================================
// Legal Regions, Trips, Membership, Invites
// ============================================================

Table geo.legal_regions {
  code varchar(10) [pk, note: '법정동코드 10자리']
  name varchar(100) [not null, note: '현재 row의 지역명']
  full_name varchar(200) [not null, note: '전체 법정동명']
  level varchar(20) [not null, note: 'SIDO, SIGUNGU, EUPMYEONDONG']
  parent_code varchar(10)
  sido_code varchar(2) [not null]
  sigungu_code varchar(5)
  eupmyeondong_code varchar(8)
  raw_status varchar(10) [not null, note: '존재, 폐지']
  is_active boolean [not null, default: true]
  synced_at timestamptz [not null]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (level, is_active)
    parent_code
    sido_code
    sigungu_code
    is_active
  }
}

Table geo.legal_region_sync_logs {
  id bigserial [pk]
  source varchar(50) [not null, note: 'code.go.kr, dump, api']
  source_file_name varchar(255)
  total_count int [not null, default: 0]
  inserted_count int [not null, default: 0]
  updated_count int [not null, default: 0]
  deactivated_count int [not null, default: 0]
  started_at timestamptz [not null]
  finished_at timestamptz
  status varchar(20) [not null, note: 'SUCCESS, FAILED']
  error_message text

  Indexes {
    source
    status
    started_at
  }
}

Table trip.trips {
  id uuid [pk, default: `gen_random_uuid()`]
  owner_user_id uuid [not null]
  title varchar(160) [not null]
  display_destination varchar(160)
  status varchar(30) [not null, default: 'ACTIVE', note: 'ACTIVE, ARCHIVED, DELETED']
  itinerary_version bigint [not null, default: 0]
  retripped_from_post_id uuid
  retripped_from_snapshot_version int
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    owner_user_id
    status
    retripped_from_post_id
    created_at
  }
}

Table trip.trip_regions {
  trip_id uuid [not null]
  legal_region_code varchar(10) [not null, note: 'References geo.legal_regions.code.']
  sort_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (trip_id, legal_region_code) [pk]
    legal_region_code
  }
}

Table trip.trip_members {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  user_id uuid [not null]
  role varchar(20) [not null, default: 'MEMBER', note: 'MVP stores MEMBER only. OWNER privileges are derived from trip.trips.owner_user_id; OWNER member role is reserved for a future multi-owner model if introduced.']
  status varchar(30) [not null, default: 'ACTIVE', note: 'ACTIVE, LEFT, REMOVED']
  joined_at timestamptz [not null, default: `now()`]
  left_at timestamptz
  removed_by_user_id uuid

  Indexes {
    (trip_id, user_id) [unique]
    user_id
    (trip_id, role)
    status
  }
}

Table trip.trip_invites {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  created_by_user_id uuid [not null]
  invitee_user_id uuid [note: 'Set for direct in-app invite to an existing user.']
  invite_code varchar(32) [not null]
  invite_token_hash text [not null, unique]
  status varchar(30) [not null, default: 'PENDING', note: 'PENDING, ACCEPTED, REVOKED, EXPIRED']
  expires_at timestamptz
  accepted_by_user_id uuid
  accepted_at timestamptz
  revoked_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    trip_id
    invitee_user_id
    invite_code
    invite_token_hash [unique]
    status
  }
}

Table notification.notifications {
  id uuid [pk, default: `gen_random_uuid()`]
  recipient_user_id uuid [not null]
  actor_user_id uuid
  trip_id uuid
  type varchar(60) [not null, note: 'MVP creates direct trip invite notifications only.']
  title varchar(160) [not null]
  body text
  payload jsonb [note: 'For MVP TRIP_INVITE notifications, typed payload contains tripId, inviteId, inviteCode, and routing fields.']
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (recipient_user_id, read_at)
    (recipient_user_id, created_at)
    trip_id
  }
}

// ============================================================
// Itinerary, Routes, Map Drawings, Map Matching
// ============================================================

Table itinerary.itinerary_days {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  group_type varchar(30) [not null, default: 'DAY', note: 'DAY or UNSCHEDULED. UNSCHEDULED is the 일차 미정 group.']
  day_number int [note: 'Required for DAY, null for UNSCHEDULED.']
  date date
  title varchar(120)
  sort_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    trip_id
    (trip_id, group_type, day_number) [unique, note: 'Use a partial/NULLS NOT DISTINCT unique index so each trip has only one UNSCHEDULED group.']
    (trip_id, sort_order)
  }
}

Table itinerary.itinerary_items {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  itinerary_day_id uuid [not null]
  sort_order int [not null]
  item_type varchar(30) [not null, default: 'PLACE', note: 'PLACE or CUSTOM_PLACE. Custom place details live on the item only.']
  place_provider varchar(40)
  external_place_id varchar(120)
  place_name varchar(240) [not null]
  address text
  lat decimal(10,7)
  lng decimal(10,7)
  thumbnail_url text
  source_status varchar(30) [not null, default: 'AVAILABLE', note: 'AVAILABLE, DELETED, UNKNOWN']
  created_by_user_id uuid
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    itinerary_day_id
    (itinerary_day_id, sort_order)
    (place_provider, external_place_id)
    deleted_at
  }
}

Table itinerary.trip_routes {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  origin_itinerary_item_id uuid [not null]
  destination_itinerary_item_id uuid [not null]
  mode varchar(20) [not null, note: 'DRIVING or WALKING']
  provider varchar(40) [not null, default: 'MAPBOX']
  provider_profile varchar(80) [not null, note: 'mapbox/driving or mapbox/walking']
  geometry_format varchar(30) [not null, default: 'GEOJSON']
  geometry jsonb [not null, note: 'Final snapped route geometry only. Map matching preview strokes are not persisted as route data.']
  distance_meters decimal(12,2)
  duration_seconds decimal(12,2)
  confidence decimal(5,4)
  created_by_user_id uuid
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    origin_itinerary_item_id
    destination_itinerary_item_id
    (origin_itinerary_item_id, destination_itinerary_item_id)
    deleted_at
  }

  Note: 'A route is one snapped segment between two itinerary items. Application enforces that both items belong to the same trip.'
}

Table itinerary.route_match_requests {
  id bigserial [pk]
  trip_id uuid [not null]
  trip_route_id uuid
  origin_itinerary_item_id uuid [not null]
  destination_itinerary_item_id uuid [not null]
  requested_by_user_id uuid [not null]
  provider varchar(40) [not null, default: 'MAPBOX']
  provider_profile varchar(80) [not null]
  input_coordinates jsonb [not null, note: 'Simplified/downsampled coordinates sent to provider.']
  radiuses jsonb
  tidy boolean [not null, default: false]
  request_hash varchar(128)
  status varchar(30) [not null, default: 'PENDING', note: 'PENDING, SUCCEEDED, FAILED']
  confidence decimal(5,4)
  distance_meters decimal(12,2)
  duration_seconds decimal(12,2)
  tracepoints jsonb
  matchings_metadata jsonb
  error_code varchar(120)
  error_message text
  created_at timestamptz [not null, default: `now()`]
  completed_at timestamptz

  Indexes {
    trip_id
    trip_route_id
    origin_itinerary_item_id
    destination_itinerary_item_id
    requested_by_user_id
    request_hash
    status
    created_at
  }
}

Table itinerary.map_drawings {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  itinerary_day_id uuid [note: 'Optional day scope. Null means trip-wide map drawing.']
  drawing_type varchar(30) [not null, note: 'FREEHAND, LINE, POLYGON, MARKER, TEXT']
  geometry_format varchar(30) [not null, default: 'GEOJSON']
  geometry jsonb [not null, note: 'Saved drawing geometry. Live preview strokes are sent over WebSocket and are not persisted until saved.']
  style jsonb
  label varchar(160)
  sort_order int [not null, default: 0]
  version bigint [not null, default: 0]
  created_by_user_id uuid [not null]
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    itinerary_day_id
    created_by_user_id
    drawing_type
    (trip_id, sort_order)
    deleted_at
  }
}

// ============================================================
// Collaboration Commands, Undo/Redo, Audit Trail
// ============================================================

Table collab.collaboration_command_events {
  id bigserial [pk]
  trip_id uuid [not null]
  actor_user_id uuid [not null]
  websocket_session_id varchar(120)
  source varchar(30) [not null, note: 'USER, AI_TOOL, UNDO, REDO']
  command_type varchar(80) [not null]
  aggregate_type varchar(80) [not null]
  aggregate_id uuid
  version_before bigint
  version_after bigint
  payload jsonb [not null]
  inverse_payload jsonb
  redo_payload jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    trip_id
    actor_user_id
    websocket_session_id
    command_type
    created_at
  }
}

// ============================================================
// Notes and Checklists
// ============================================================

Table planning.trip_notes {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  scope_type varchar(20) [not null, note: 'TRIP or DAY']
  itinerary_day_id uuid [note: 'Required for DAY scope, null for TRIP scope. Includes UNSCHEDULED day/group.']
  content text [not null, default: '']
  version bigint [not null, default: 0]
  created_by_user_id uuid
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    itinerary_day_id
    (trip_id, scope_type, itinerary_day_id) [unique, note: 'Use NULLS NOT DISTINCT or partial unique indexes for singleton TRIP note.']
  }
}

Table planning.checklists {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  scope_type varchar(20) [not null, note: 'TRIP or DAY']
  itinerary_day_id uuid [note: 'Required for DAY scope, null for TRIP scope. Includes UNSCHEDULED day/group.']
  title varchar(120)
  version bigint [not null, default: 0]
  created_by_user_id uuid
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    itinerary_day_id
    (trip_id, scope_type, itinerary_day_id) [unique, note: 'Use NULLS NOT DISTINCT or partial unique indexes for singleton TRIP checklist.']
  }
}

Table planning.checklist_items {
  id uuid [pk, default: `gen_random_uuid()`]
  checklist_id uuid [not null]
  sort_order int [not null]
  content text [not null]
  created_by_user_id uuid
  updated_by_user_id uuid
  deleted_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    checklist_id
    (checklist_id, sort_order)
    deleted_at
  }
}

Table planning.checklist_item_member_statuses {
  checklist_item_id uuid [not null]
  user_id uuid [not null, note: 'Trip member whose completion state is represented.']
  is_completed boolean [not null, default: false]
  completed_at timestamptz
  updated_by_user_id uuid [note: 'Actor who changed this member status. Usually the same as user_id.']
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (checklist_item_id, user_id) [pk]
    user_id
    is_completed
    updated_at
  }

  Note: 'Per-member checklist state. Application enforces that user_id is an active member of the checklist trip. MVP allows a member to update only their own status; updated_by_user_id records the actor.'
}

// ============================================================
// Trip Chat
// ============================================================

Table chat.trip_chat_messages {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  sender_user_id uuid [not null]
  content text [not null]
  deleted_by_user_id uuid
  deleted_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    trip_id
    sender_user_id
    created_at
    (trip_id, created_at, id)
    deleted_at
  }

  Note: 'MVP chat message list uses offset/limit infinite scroll ordered by created_at DESC, id DESC.'
}

// ============================================================
// Places, Swipe, Preference Tags, AI Enrichment
// ============================================================

Table preference.preference_tags {
  id uuid [pk, default: `gen_random_uuid()`]
  code varchar(80) [not null, unique]
  display_name varchar(120) [not null]
  group_code varchar(80) [not null, note: 'One of fixed groups: nature_scene, history_culture, activity, mood, space_context.']
  tag_type varchar(20) [not null, default: 'TAG', note: 'GROUP, TAG. GROUP rows organize the fixed whitelist and cannot be assigned to places.']
  parent_tag_id uuid
  description text
  is_selectable boolean [not null, default: true, note: 'Only selectable TAG rows can be assigned to places.']
  is_active boolean [not null, default: true]
  dictionary_version varchar(80) [not null, default: 'preference-tags-v1']
  sort_order int
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    code [unique]
    group_code
    tag_type
    parent_tag_id
    is_selectable
    is_active
    dictionary_version
  }

  Note: 'Fixed whitelist only. Seed data must match .agent/docs/product-specs/preference_tagging_policy.md exactly.'
}

Table preference.place_tag_enrichments {
  id uuid [pk, default: `gen_random_uuid()`]
  provider varchar(40) [not null, note: 'KTO or other future provider.']
  external_place_id varchar(120) [not null]
  source_modified_at timestamptz
  source_hash varchar(128)
  status varchar(30) [not null, default: 'PENDING', note: 'PENDING, SUCCEEDED, FAILED, STALE']
  model_provider varchar(80)
  model_name varchar(120)
  prompt_version varchar(80)
  tag_dictionary_version varchar(80)
  selection_policy_version varchar(80)
  tag_statistic_run_id uuid
  candidate_count int [not null, default: 0]
  selected_count int [not null, default: 0]
  error_message text
  enriched_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (provider, external_place_id)
    source_hash
    status
    tag_statistic_run_id
    enriched_at
  }

  Note: 'Tag dictionary, prompt, and model versions determine stale marking and background re-enrichment.'
}

Table preference.place_tag_enrichment_candidates {
  id uuid [pk, default: `gen_random_uuid()`]
  enrichment_id uuid [not null]
  candidate_code varchar(80) [not null]
  matched_tag_id uuid
  confidence decimal(5,4)
  weight decimal(8,4)
  selection_score decimal(8,6)
  status varchar(40) [not null, note: 'SELECTED, REJECTED_OUT_OF_DICTIONARY, REJECTED_LOW_CONFIDENCE, REJECTED_LOW_SCORE, REJECTED_DUPLICATE, REJECTED_LIMIT']
  rationale text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    enrichment_id
    candidate_code
    matched_tag_id
    status
  }

  Note: 'Stores all model candidates. Whitelist misses are preserved only as rejected candidates and never become serving tags.'
}

Table preference.place_tag_enrichment_tags {
  enrichment_id uuid [not null]
  tag_id uuid [not null]
  confidence decimal(5,4) [not null]
  weight decimal(8,4) [not null]
  preference_discrimination_snapshot decimal(8,6)
  selection_score decimal(8,6)
  rank_order int [not null]
  tag_statistic_run_id uuid
  rationale text

  Indexes {
    (enrichment_id, tag_id) [pk]
    tag_id
    tag_statistic_run_id
    rank_order
  }

  Note: 'Serving place tags selected from the fixed whitelist. Recommendation uses confidence, weight, and preference_discrimination snapshot/statistics.'
}

Table preference.tag_statistic_runs {
  id uuid [pk, default: `gen_random_uuid()`]
  source varchar(30) [not null, note: 'AI_ONLY_DEFAULT, SYNTHETIC_PERSONA, REAL_USER']
  status varchar(30) [not null, default: 'PENDING', note: 'PENDING, RUNNING, SUCCEEDED, FAILED, ARCHIVED']
  alpha decimal(8,4) [not null, default: 100]
  global_positive_rate decimal(8,6)
  total_reaction_count bigint [not null, default: 0]
  positive_reaction_count bigint [not null, default: 0]
  generator_version varchar(80)
  error_message text
  is_serving boolean [not null, default: false]
  started_at timestamptz
  completed_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    source
    status
    is_serving
    completed_at
  }

  Note: 'Projection run for preference_discrimination. Serving path must not mix SYNTHETIC_PERSONA and REAL_USER runs.'
}

Table preference.tag_statistics {
  run_id uuid [not null]
  tag_id uuid [not null]
  preference_discrimination decimal(8,6) [not null]
  smoothed_positive_rate decimal(8,6)
  positive_count bigint [not null, default: 0]
  reaction_count bigint [not null, default: 0]
  calculated_at timestamptz [not null, default: `now()`]

  Indexes {
    (run_id, tag_id) [pk]
    tag_id
    preference_discrimination
  }
}

Table preference.synthetic_personas {
  id uuid [pk, default: `gen_random_uuid()`]
  persona_key varchar(80) [not null, unique]
  display_name varchar(120) [not null]
  description text [not null]
  generator_version varchar(80) [not null]
  seed bigint [not null]
  noise_rate decimal(5,4) [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    persona_key [unique]
    generator_version
    is_active
  }

  Note: 'Exactly 50 active personas per generator version for cold-start synthetic swipe generation.'
}

Table preference.synthetic_persona_tag_preferences {
  persona_id uuid [not null]
  tag_id uuid [not null]
  preference_type varchar(30) [not null, note: 'HARD_LIKE, HARD_DISLIKE, SOFT_LIKE, SOFT_DISLIKE, NEUTRAL']
  preference_strength decimal(8,4) [not null, note: 'Signed strength used by the persona swipe generator.']

  Indexes {
    (persona_id, tag_id) [pk]
    tag_id
    preference_type
  }
}

Table preference.synthetic_swipe_events {
  id bigserial [pk]
  persona_id uuid [not null]
  provider varchar(40) [not null]
  external_place_id varchar(120) [not null]
  reaction varchar(20) [not null, note: 'LIKE, NOPE, SUPER_LIKE']
  place_tag_enrichment_id uuid
  generator_version varchar(80) [not null]
  seed bigint [not null]
  persona_place_score decimal(10,6)
  generated_at timestamptz [not null, default: `now()`]

  Indexes {
    persona_id
    (provider, external_place_id)
    reaction
    generator_version
    generated_at
  }

  Note: 'Synthetic cold-start events are kept separate from real user_swipe_events.'
}

Table preference.user_place_reactions {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  provider varchar(40) [not null]
  external_place_id varchar(120) [not null]
  reaction varchar(20) [not null, note: 'LIKE, NOPE, SUPER_LIKE']
  reaction_count int [not null, default: 1]
  first_reacted_at timestamptz [not null, default: `now()`]
  last_reacted_at timestamptz [not null, default: `now()`]
  source_modified_at timestamptz
  place_tag_enrichment_id uuid

  Indexes {
    (user_id, provider, external_place_id) [unique]
    user_id
    reaction
    (provider, external_place_id)
  }
}

Table preference.user_swipe_events {
  id bigserial [pk]
  user_id uuid [not null]
  provider varchar(40) [not null]
  external_place_id varchar(120) [not null]
  reaction varchar(20) [not null, note: 'LIKE, NOPE, SUPER_LIKE']
  previous_reaction varchar(20)
  feed_context jsonb [note: 'Reserved for future feed metadata. MVP does not store trip context and does not derive preferences per trip.']
  source_modified_at timestamptz
  place_tag_enrichment_id uuid
  occurred_at timestamptz [not null, default: `now()`]

  Indexes {
    user_id
    (provider, external_place_id)
    reaction
    occurred_at
  }
}

Table preference.user_preference_tag_weights {
  user_id uuid [not null]
  tag_id uuid [not null]
  raw_score decimal(14,4) [not null, default: 0]
  normalized_score decimal(8,6) [not null, default: 0, note: 'Capped score such as tanh(raw_score / scale).']
  like_count int [not null, default: 0]
  super_like_count int [not null, default: 0]
  nope_count int [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    (user_id, tag_id) [pk]
    tag_id
    normalized_score
  }
}

Table preference.user_saved_places {
  id uuid [pk, default: `gen_random_uuid()`]
  user_id uuid [not null]
  provider varchar(40) [not null]
  external_place_id varchar(120) [not null]
  created_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    (user_id, provider, external_place_id) [unique]
    (provider, external_place_id)
    deleted_at
  }

  Note: 'Application must allow saving only when the user SUPER_LIKEs the place.'
}

// ============================================================
// AI Agent Session and Tool Calling
// ============================================================

Table ai.ai_chat_sessions {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null, unique]
  status varchar(30) [not null, default: 'ACTIVE']
  summary text
  summary_updated_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  expires_at timestamptz
  deleted_at timestamptz

  Indexes {
    trip_id [unique]
    status
  }
}

Table ai.ai_chat_messages {
  id uuid [pk, default: `gen_random_uuid()`]
  session_id uuid [not null]
  requester_user_id uuid [note: 'Set for user messages and for assistant messages caused by a requester.']
  role varchar(30) [not null, note: 'SYSTEM, USER, ASSISTANT, TOOL']
  content text [not null]
  tool_call_id uuid
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    session_id
    requester_user_id
    role
    created_at
    (session_id, created_at, id)
    tool_call_id
  }

  Note: 'MVP AI message list uses offset/limit infinite scroll ordered by created_at DESC, id DESC.'
}

Table ai.ai_tool_calls {
  id uuid [pk, default: `gen_random_uuid()`]
  session_id uuid [not null]
  trip_id uuid [not null]
  request_message_id uuid
  result_message_id uuid
  requested_by_user_id uuid [not null]
  websocket_session_id varchar(120)
  tool_name varchar(120) [not null]
  execution_policy varchar(40) [not null, note: 'READ, REVERSIBLE_WRITE, BLOCKED_HIGH_RISK']
  arguments jsonb [not null]
  result jsonb
  status varchar(40) [not null, default: 'REQUESTED', note: 'REQUESTED, SUCCEEDED, FAILED, BLOCKED']
  version_before bigint
  version_after bigint
  undo_redo_available boolean [not null, default: false]
  undo_command jsonb
  redo_command jsonb
  error_code varchar(120)
  error_message text
  created_at timestamptz [not null, default: `now()`]
  completed_at timestamptz

  Indexes {
    session_id
    trip_id
    requested_by_user_id
    tool_name
    status
    created_at
  }
}

// ============================================================
// Trip Records
// ============================================================

Table record.trip_record_entries {
  id uuid [pk, default: `gen_random_uuid()`]
  trip_id uuid [not null]
  itinerary_day_id uuid
  itinerary_item_id uuid
  uploaded_by_user_id uuid [not null]
  title varchar(160)
  caption text
  location_name varchar(240)
  lat decimal(10,7)
  lng decimal(10,7)
  taken_at timestamptz
  visibility varchar(30) [not null, default: 'TRIP_MEMBERS', note: 'TRIP_MEMBERS in MVP. PUBLIC is through community shared posts.']
  status varchar(30) [not null, default: 'ACTIVE', note: 'ACTIVE, DELETED']
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    trip_id
    itinerary_day_id
    itinerary_item_id
    uploaded_by_user_id
    taken_at
    status
    created_at
  }
}

Table record.trip_record_media {
  record_entry_id uuid [not null]
  media_file_id uuid [not null]
  sort_order int [not null, default: 0]
  caption text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (record_entry_id, media_file_id) [pk]
    media_file_id
    (record_entry_id, sort_order)
  }
}

// ============================================================
// Community Posts, Comments, Reports, Retrip
// ============================================================

Table community.posts {
  id uuid [pk, default: `gen_random_uuid()`]
  source_trip_id uuid [not null]
  published_by_user_id uuid [not null]
  cover_media_file_id uuid
  visibility varchar(20) [not null, note: 'PUBLIC or UNLISTED in MVP.']
  share_token_hash varchar(255) [unique, note: 'Required when visibility is UNLISTED. Raw share token is returned only when generated/rotated and is never stored.']
  share_token_created_at timestamptz
  share_token_rotated_at timestamptz
  title varchar(180) [not null]
  summary text
  snapshot_version int [not null, default: 1]
  snapshot jsonb [not null, note: 'Immutable public rendering snapshot. Normalized snapshot tables support querying/rendering.']
  like_count int [not null, default: 0]
  retrip_count int [not null, default: 0]
  comment_count int [not null, default: 0]
  media_count int [not null, default: 0]
  moderation_status varchar(30) [not null, default: 'VISIBLE', note: 'VISIBLE, HIDDEN, DELETED']
  moderated_by_user_id uuid
  moderated_at timestamptz
  moderation_reason text
  published_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
  deleted_at timestamptz

  Indexes {
    source_trip_id
    published_by_user_id
    cover_media_file_id
    visibility
    share_token_hash [unique]
    moderation_status
    published_at
  }

  Note: 'Denormalized counters are updated in the same transaction as like/comment/retrip/media writes and can be repaired by an operational recompute job.'
}

Table community.post_snapshot_days {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id uuid [not null]
  group_type varchar(30) [not null, note: 'DAY or UNSCHEDULED']
  day_number int
  date date
  title varchar(120)
  sort_order int [not null, default: 0]

  Indexes {
    post_id
    (post_id, sort_order)
  }
}

Table community.post_snapshot_items {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id uuid [not null]
  snapshot_day_id uuid [not null]
  sort_order int [not null]
  place_provider varchar(40)
  external_place_id varchar(120)
  source_status varchar(30) [not null, default: 'AVAILABLE', note: 'AVAILABLE, DELETED, UNKNOWN']
  place_name varchar(240) [not null]
  address text
  lat decimal(10,7)
  lng decimal(10,7)
  thumbnail_url text

  Indexes {
    post_id
    snapshot_day_id
    (snapshot_day_id, sort_order)
    (place_provider, external_place_id)
  }
}

Table community.post_snapshot_routes {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id uuid [not null]
  origin_snapshot_item_id uuid [not null]
  destination_snapshot_item_id uuid [not null]
  mode varchar(20) [not null]
  geometry_format varchar(30) [not null, default: 'GEOJSON']
  geometry jsonb [not null]
  distance_meters decimal(12,2)
  duration_seconds decimal(12,2)

  Indexes {
    post_id
    origin_snapshot_item_id
    destination_snapshot_item_id
    (origin_snapshot_item_id, destination_snapshot_item_id)
  }

  Note: 'Published route snapshot preserves the item-to-item segment from the source itinerary.'
}

Table community.post_media {
  post_id uuid [not null]
  media_file_id uuid [not null]
  sort_order int [not null, default: 0]
  caption text
  created_by_user_id uuid
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (post_id, media_file_id) [pk]
    media_file_id
    (post_id, sort_order)
  }
}

Table community.hashtags {
  id uuid [pk, default: `gen_random_uuid()`]
  name varchar(80) [not null, unique]
  normalized_name varchar(80) [not null, unique]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    name [unique]
    normalized_name [unique]
  }
}

Table community.post_hashtags {
  post_id uuid [not null]
  hashtag_id uuid [not null]
  sort_order int [not null, default: 0]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (post_id, hashtag_id) [pk]
    hashtag_id
    (post_id, sort_order)
  }
}

Table community.post_likes {
  post_id uuid [not null]
  user_id uuid [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    (post_id, user_id) [pk]
    user_id
  }
}

Table community.post_retrips {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id uuid [not null]
  user_id uuid [not null]
  new_trip_id uuid [not null]
  snapshot_version int [not null]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    post_id
    user_id
    new_trip_id [unique]
    created_at
  }
}

Table community.post_comments {
  id uuid [pk, default: `gen_random_uuid()`]
  post_id uuid [not null]
  parent_comment_id uuid [note: 'Null for root comments. Non-null only for one-level replies.']
  author_user_id uuid [not null]
  content text [not null]
  depth int [not null, default: 0, note: '0 comment, 1 reply. App enforces no deeper nesting.']
  moderation_status varchar(30) [not null, default: 'VISIBLE', note: 'VISIBLE, HIDDEN, DELETED']
  deleted_by_user_id uuid
  deleted_at timestamptz
  moderated_by_user_id uuid
  moderated_at timestamptz
  moderation_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  Indexes {
    post_id
    parent_comment_id
    author_user_id
    moderation_status
    created_at
  }
}

Table community.report_reasons {
  id smallserial [pk]
  code varchar(60) [not null, unique, note: 'SPAM, INAPPROPRIATE, HARASSMENT_OR_HATE, RIGHTS_VIOLATION, OTHER']
  display_name varchar(120) [not null]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    code [unique]
    is_active
  }

  Note: 'MVP exposes active reasons through GET /community/report-reasons. Admin CRUD is deferred.'
}

Table community.content_reports {
  id uuid [pk, default: `gen_random_uuid()`]
  reporter_user_id uuid [not null]
  target_type varchar(40) [not null, note: 'POST or POST_COMMENT']
  target_id uuid [not null, note: 'Polymorphic target id; app validates target existence.']
  reason_id smallint [not null]
  detail text
  status varchar(30) [not null, default: 'OPEN', note: 'OPEN, REVIEWING, RESOLVED, REJECTED']
  created_at timestamptz [not null, default: `now()`]
  resolved_by_user_id uuid
  resolved_at timestamptz
  resolution_note text

  Indexes {
    (reporter_user_id, target_type, target_id) [unique]
    (target_type, target_id)
    reason_id
    status
    created_at
  }
}

Table community.moderation_actions {
  id uuid [pk, default: `gen_random_uuid()`]
  moderator_user_id uuid [not null]
  target_type varchar(40) [not null, note: 'POST or POST_COMMENT']
  target_id uuid [not null]
  action varchar(40) [not null, note: 'HIDE, RESTORE, DELETE']
  moderation_status varchar(30) [not null]
  moderation_reason text
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    moderator_user_id
    (target_type, target_id)
    action
    created_at
  }
}

// ============================================================
// Operational Audit
// ============================================================

Table ops.audit_logs {
  id bigserial [pk]
  actor_user_id uuid
  action varchar(120) [not null]
  target_type varchar(80)
  target_id uuid
  ip_address varchar(64)
  user_agent text
  metadata jsonb
  created_at timestamptz [not null, default: `now()`]

  Indexes {
    actor_user_id
    (target_type, target_id)
    action
    created_at
  }

  Note: 'Generic audit logs are not exposed through a broad MVP admin API. If exposed later, restrict to SUPER_ADMIN and mask sensitive fields.'
}

